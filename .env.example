APP_NAME="DGC API"
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Database — PostgreSQL 16+
DATABASE_URL=postgresql+asyncpg://dgc:password@localhost:5432/dgc
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_ECHO=false

# JWT
JWT_SECRET=change-me-to-a-random-256-bit-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_MINUTES=20160

# LINE Notify
LINE_NOTIFY_TOKEN=
LINE_NOTIFY_URL=https://notify-api.line.me/api/notify

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="DGC <noreply@example.com>"
SMTP_USE_TLS=true

# Object storage — S3-compatible (MinIO locally, Cloudflare R2 / AWS S3 in prod)
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=dgc-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=
S3_PRESIGNED_URL_TTL_SECONDS=3600
